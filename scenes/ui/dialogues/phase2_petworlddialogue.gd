		{
			"speaker": "You",
			"text": "…",
			"portrait": "res://icons/you.png"
		},
		{
			"speaker": "You",
			"text": "Registration is successful… i need to fill the UC 5000 entry fee",
			"portrait": "res://icons/you.png"
		}
	]
